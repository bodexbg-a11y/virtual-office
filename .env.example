# ===== Database (Neon/Postgres) =====
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ===== Server =====
PORT=3000
NODE_ENV=development
ADMIN_PASSWORD=1111
AUTH_SECRET=change_me_for_production

# ===== Google Sheets =====
# 1. Go to https://console.cloud.google.com
# 2. Create project → Enable Google Sheets API
# 3. Create Service Account → Download JSON key
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here
# Optional: comma-separated response spreadsheet IDs for Google Forms.
# Share each response spreadsheet with the same service account email.
GOOGLE_FORM_SPREADSHEET_IDS=

# Optional: write Mark/Maria reports to Google Sheets too
# By default reports are saved in DB only.
AGENT_REPORTS_TO_SHEETS=false

# ===== Facebook Ads =====
# 1. Go to https://developers.facebook.com
# 2. Create App → Add Marketing API
# 3. Get access token from Graph API Explorer
FB_APP_ID=your_app_id
FB_APP_SECRET=your_app_secret
FB_ACCESS_TOKEN=your_long_lived_access_token
FB_AD_ACCOUNT_ID=act_your_ad_account_id

# ===== Mark Search Providers (optional) =====
# 1) Preferred: SerpAPI (Google results)
SERPAPI_KEY=
# 2) Alternative: Google Custom Search API
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
